# Production Environment Variables for DrawDB
# Copy this to .env.production

# Frontend Configuration
VITE_APP_ENV=production
VITE_APP_NAME=DrawDB
VITE_APP_VERSION=1.0.0

# Backend API Configuration
VITE_BACKEND_URL=https://api.yourdomain.com/api

# Production Features
VITE_DEBUG=false
VITE_HOT_RELOAD=false

# Analytics
VITE_VERCEL_ANALYTICS_ENABLED=true
VITE_SPEED_INSIGHTS_ENABLED=true

# CORS Origins (for backend reference)
CORS_ORIGIN=https://yourdomain.com

# Database
DATABASE_URL=postgresql://drawdb:strong_password_here@postgres:5432/drawdb
REDIS_URL=redis://redis:6379

# Email Configuration
SMTP_HOST=your-smtp-server.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# GitHub Integration
GITHUB_CLIENT_ID=your_production_github_client_id
GITHUB_CLIENT_SECRET=your_production_github_client_secret

# Security
JWT_SECRET=your-super-secure-production-jwt-secret-key-here
API_RATE_LIMIT=100

# Ports (internal container ports)
FRONTEND_PORT=80
BACKEND_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379

# SSL/TLS
SSL_ENABLED=true
FORCE_HTTPS=true